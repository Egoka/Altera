    "@graphql-tools/merge": "^9.1.0",
    "@graphql-yoga/plugin-csrf-prevention": "^3.15.1",
    "@neondatabase/serverless": "^1.0.1",
    "@prisma/client": "6.12.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "graphql": "^16.11.0",
    "graphql-yoga": "^5.15.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
